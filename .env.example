APP_NAME="Safe Reports"
DJANGO_DEBUG=true
DJANGO_SECRET_KEY="change-me"
# Optional Fernet key for encrypted customer secrets. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=""
DJANGO_ALLOWED_HOSTS="127.0.0.1,localhost"

# Use this when running against Postgres. Omit it to use local SQLite.
# DATABASE_URL="postgres://user:password@localhost:5432/safe_reports"

REPORT_QUERY_TIMEOUT_SECONDS=120
REPORT_CACHE_TTL_SECONDS=86400
REPORT_MAX_ROWS=50000
REPORT_MAX_RAW_BYTES=52428800
REPORT_MAX_COMPRESSED_BYTES=10485760

# Bundled read-only demo SaaS sales data source. This creates a SQLite
# DatabaseConnection named "Demo SaaS Sales" for each organization.
ENABLE_DEMO_DATABASE_CONNECTION=true
DEMO_DATABASE_CONNECTION_NAME="Demo SaaS Sales"
